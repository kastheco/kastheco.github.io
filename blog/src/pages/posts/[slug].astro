---
import BlogLayout from '../../layouts/BlogLayout.astro';
import TuiBox from '../../components/TuiBox.astro';
import EncryptedPost from '../../components/EncryptedPost.astro';
import { render } from 'astro:content';
import { getPublishedPosts, formatPostDate } from '../../lib/posts';
import { slugifyTag } from '../../lib/tags';
import type { PostEntry } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts({
    includeDrafts: false,
    includeUnlisted: true,
  });
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: PostEntry };

const { post } = Astro.props;
const isEncrypted = !!post.data.cipher;

// Encrypted posts skip the normal markdown render — the body lives inside
// the cipher blob and is only available client-side after unlock.
const rendered = isEncrypted ? null : await render(post);
const Content = rendered?.Content;
const tocHeadings = rendered
  ? rendered.headings.filter((h) => h.depth === 2 || h.depth === 3)
  : [];
---

<BlogLayout
  title={isEncrypted ? 'locked' : post.data.title}
  description={isEncrypted ? undefined : post.data.description}
  wide
  ogType={isEncrypted ? 'website' : 'article'}
  pubDate={isEncrypted ? undefined : post.data.pubDate}
  updated={isEncrypted ? undefined : post.data.updated}
  tags={isEncrypted ? [] : post.data.tags}
  noindex={isEncrypted || post.data.unlisted}
>
  {isEncrypted ? (
    <EncryptedPost cipher={post.data.cipher!} />
  ) : (
  <div class="post-layout">
    {tocHeadings.length > 0 && (
      <aside class="toc" data-toc>
        <button class="toc-toggle" type="button" aria-expanded="true" aria-controls="toc-nav">
          <span class="toc-chevron" aria-hidden="true">▾</span>
          <span class="toc-title-text">contents</span>
        </button>
        <div class="toc-nav-wrap">
          <nav id="toc-nav">
            <ul>
              <li class="toc-level-2"><a href="#intro">intro</a></li>
              {tocHeadings.map((h) => (
                <li class={`toc-level-${h.depth}`}>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        </div>
      </aside>
    )}

    <article class="post-main" id="intro">
      <TuiBox title={post.data.title} titleBadge={post.data.titleBadge} accent="pink" focused>
        <div class="post-meta">
          <div class="post-meta-dates">
            <span class="date">published {formatPostDate(post.data.pubDate)}</span>
            {post.data.updated && (
              <span class="read-time">· updated {formatPostDate(post.data.updated)}</span>
            )}
          </div>
          {post.data.tags.length > 0 && (
            <div class="post-meta-tags">
              {post.data.tags.map((tag) => (
                <a href={`/blog/tags/${slugifyTag(tag)}/`} class="tag-chip">#{tag}</a>
              ))}
            </div>
          )}
        </div>

        {post.data.description && (
          <p class="post-description">{post.data.description}</p>
        )}
      </TuiBox>

      <div class="prose">
        {Content && <Content />}
      </div>
    </article>
  </div>
  )}

  {!isEncrypted && (
  <script is:inline>
    (function () {
      const toc = document.querySelector('[data-toc]');
      if (!toc) return;
      const btn = toc.querySelector('.toc-toggle');
      const mq = window.matchMedia('(max-width: 720px)');

      function setCollapsed(collapsed) {
        toc.classList.toggle('collapsed', collapsed);
        btn.setAttribute('aria-expanded', String(!collapsed));
      }

      // collapsed by default on mobile, expanded on desktop
      setCollapsed(mq.matches);
      mq.addEventListener('change', (e) => setCollapsed(e.matches));

      btn.addEventListener('click', () => {
        setCollapsed(!toc.classList.contains('collapsed'));
      });

      // on mobile: collapse instantly, then smooth-scroll to the target.
      // doing this in the wrong order makes the layout shift after the scroll
      // and dumps the user past the heading they clicked.
      toc.querySelectorAll('nav a').forEach((a) => {
        a.addEventListener('click', (e) => {
          if (!mq.matches) return;
          const href = a.getAttribute('href');
          if (!href || !href.startsWith('#')) return;
          const target = document.querySelector(href);
          if (!target) return;
          e.preventDefault();

          toc.classList.add('no-anim');
          setCollapsed(true);
          // force a synchronous layout flush so the collapse takes effect now
          void toc.offsetHeight;
          requestAnimationFrame(() => {
            toc.classList.remove('no-anim');
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            history.replaceState(null, '', href);
          });
        });
      });
    })();
  </script>
  )}
</BlogLayout>
