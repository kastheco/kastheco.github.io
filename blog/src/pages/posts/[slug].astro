---
import BlogLayout from '../../layouts/BlogLayout.astro';
import TuiBox from '../../components/TuiBox.astro';
import { render } from 'astro:content';
import { getPublishedPosts, formatPostDate } from '../../lib/posts';
import { slugifyTag } from '../../lib/tags';
import type { PostEntry } from '../../lib/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts({ includeDrafts: false });
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: PostEntry };

const { post } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
  wide
  ogType="article"
  pubDate={post.data.pubDate}
  updated={post.data.updated}
  tags={post.data.tags}
>
  <div class="post-layout">
    {tocHeadings.length > 0 && (
      <aside class="toc">
        <div class="toc-title">contents</div>
        <nav>
          <ul>
            {tocHeadings.map((h) => (
              <li class={`toc-level-${h.depth}`}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}

    <article class="post-main">
      <TuiBox title={post.data.title} titleBadge={post.data.titleBadge} accent="pink" focused>
        <div class="post-meta">
          <span class="date">published {formatPostDate(post.data.pubDate)}</span>
          {post.data.updated && (
            <span class="read-time">· updated {formatPostDate(post.data.updated)}</span>
          )}
          {post.data.tags.map((tag) => (
            <a href={`/blog/tags/${slugifyTag(tag)}/`} class="tag-chip">#{tag}</a>
          ))}
        </div>

        {post.data.description && (
          <p class="post-description">{post.data.description}</p>
        )}
      </TuiBox>

      <div class="prose">
        <Content />
      </div>
    </article>
  </div>
</BlogLayout>
