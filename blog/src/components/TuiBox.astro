---
interface Props {
  title?: string;
  titleBadge?: string;
  accent?: 'purple' | 'pink' | 'green' | 'blue' | 'default';
  focused?: boolean;
  inlineTitle?: boolean;
  class?: string;
}

const {
  title = '',
  titleBadge = '',
  accent = 'default',
  focused = false,
  inlineTitle = false,
  class: className = '',
} = Astro.props;

const boxClasses = [
  'tui-box',
  `accent-${accent}`,
  focused ? 'focused' : '',
  inlineTitle ? 'inline-title' : '',
  className,
].filter(Boolean).join(' ');
---

<div class={boxClasses}>
  <div class="border-top">
    {inlineTitle ? (
      <>
        <span>╭</span><span class="border-fill">────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────</span><span>╮</span>
        {(title || titleBadge) && (
          <span class="box-title-overlay">
            {title && <span class="box-title box-title-inline">{title}</span>}
            {titleBadge && <span class="box-title-badge box-title-badge-inline">[{titleBadge}]</span>}
          </span>
        )}
      </>
    ) : (
      <>
        <span>╭</span><span>─ </span>{title && <span class="box-title box-title-inline">{title}</span>}{titleBadge && <>{'  '}<span class="box-title-badge box-title-badge-inline">[{titleBadge}]</span></>}{title && <span> </span>}<span class="border-fill">────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────</span><span>╮</span>
      </>
    )}
  </div>
  {!inlineTitle && (title || titleBadge) && (
    <div class="box-header-mobile">
      <span class="side" aria-hidden="true"></span>
      <div class="box-header-mobile-inner">
        {title && <span class="box-title">{title}</span>}
        {titleBadge && <span class="box-title-badge"> [{titleBadge}]</span>}
      </div>
      <span class="side" aria-hidden="true"></span>
    </div>
  )}
  <div class="border-mid">
    <span class="side">│</span>
    <div class="box-content">
      <slot />
    </div>
    <span class="side">│</span>
  </div>
  <div class="border-bottom">
    <span>╰</span><span class="border-fill">────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────────</span><span>╯</span>
  </div>
</div>
